  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^20.12.12",
    "@types/swagger-ui-express": "^4.1.8",
    "nodemon": "^3.1.0",
